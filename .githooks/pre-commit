#!/usr/bin/env bash
set -e

# Ensure cargo is on PATH
if [ -d "$HOME/.cargo/bin" ]; then
  export PATH="$HOME/.cargo/bin:$PATH"
fi

# === File protection checks ===
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Block .env files
ENV_FILES=$(echo "$STAGED_FILES" | grep -E '\.env($|\.)' || true)
if [ -n "$ENV_FILES" ]; then
  echo "ERROR: .env files must not be committed:"
  echo "$ENV_FILES"
  echo "Add them to .gitignore instead."
  exit 1
fi

# Warn about binary files
BINARY_FILES=""
for f in $STAGED_FILES; do
  if [ -f "$f" ] && file "$f" | grep -qE 'executable|binary|ELF|Mach-O|PE32'; then
    BINARY_FILES="$BINARY_FILES $f"
  fi
done
if [ -n "$BINARY_FILES" ]; then
  echo "WARNING: Binary files staged for commit:"
  echo "$BINARY_FILES"
  echo "Press Ctrl+C to abort, or wait 3 seconds to continue..."
  sleep 3
fi

# Warn about direct Cargo.lock modifications (without Cargo.toml changes)
LOCK_CHANGED=$(echo "$STAGED_FILES" | grep -E '^Cargo\.lock$' || true)
TOML_CHANGED=$(echo "$STAGED_FILES" | grep -E 'Cargo\.toml$' || true)
if [ -n "$LOCK_CHANGED" ] && [ -z "$TOML_CHANGED" ]; then
  echo "WARNING: Cargo.lock changed without any Cargo.toml changes."
  echo "This may indicate a manual edit. Verify this is intentional."
fi

# === Rust checks ===
if ! command -v cargo &>/dev/null; then
  echo "Warning: cargo not found, skipping Rust checks"
  exit 0
fi

echo "==> Running cargo fmt --check..."
cargo fmt --all -- --check

echo "==> Running cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings

echo "==> Pre-commit checks passed!"
